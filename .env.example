# ─── Database ─────────────────────────────────────────────────────────────────
#
# Default (SQLite — zero config, works out of the box):
DATABASE_URL="file:corebooks.db"
#
# Business/multi-user setup (PostgreSQL):
# Swap the provider in prisma/schema.prisma to "postgresql", regenerate the
# Prisma client (npx prisma generate), then replace the line above with:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/corebooks"
#
# A guided migration wizard is available in Settings → Database.
