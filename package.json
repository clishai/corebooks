{
  "name": "corebooks",
  "version": "1.0.0",
  "description": "Open-source, self-hosted accounting and bookkeeping software. Built from first principles.",
  "main": "dist/electron/main.js",
  "scripts": {
    "build": "prisma generate && tsc && cp -r src/generated dist/",
    "build:ui": "vite build",
    "build:all": "npm run build && npm run build:ui",
    "start": "node dist/index.js",
    "dev": "concurrently --kill-others-on-fail -n api,ui -c cyan,magenta \"npm run dev:api\" \"npm run dev:ui\"",
    "dev:api": "tsx watch src/index.ts",
    "dev:ui": "wait-on --timeout 30000 http://127.0.0.1:3000/health && vite",
    "dev:electron": "NODE_ENV=development electron dist/electron/main.js",
    "package": "npm run build:all && electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clishai/corebooks.git"
  },
  "keywords": [],
  "author": "clishai",
  "license": "AGPL-3.0-only",
  "type": "module",
  "bugs": {
    "url": "https://github.com/clishai/corebooks/issues"
  },
  "homepage": "https://github.com/clishai/corebooks#readme",
  "build": {
    "appId": "com.corebooks.app",
    "productName": "corebooks",
    "artifactName": "${productName}-${os}-${arch}.${ext}",
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/@prisma/adapter-better-sqlite3/**"
    ],
    "files": [
      "dist/**/*",
      "!dist/**/*.map"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.finance"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "clishai",
        "repo": "corebooks"
      }
    ]
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/vite": "^4.2.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.2.1",
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^2.0.0",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "@fastify/sensible": "^6.0.4",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@noble/hashes": "^2.2.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@scure/bip39": "^2.2.0",
    "chokidar": "^5.0.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "prisma": "^7.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2"
  }
}
