generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum AccountType {
  Asset
  Liability
  Equity
  Revenue
  Expense
}

enum NormalBalance {
  debit
  credit
}

enum EntryStatus {
  Draft
  Posted
}

enum LineType {
  debit
  credit
}

model Account {
  id             String          @id @default(cuid())
  number         String          @unique
  name           String
  type           AccountType
  normalBalance  NormalBalance
  isContra       Boolean         @default(false)
  contraTo       AccountType?
  classification String?
  lines          JournalLine[]
  recurringLines RecurringLine[]
}

model JournalEntry {
  id            String        @id @default(cuid())
  date          DateTime
  memo          String
  status        EntryStatus
  paymentMethod String?
  reversalOf    String?
  postedVia     String?
  sourceType    String?
  sourceId      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  lines         JournalLine[]
}

model JournalLine {
  id        String       @id @default(cuid())
  entryId   String
  accountId String
  amount    Int
  type      LineType
  entry     JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account   Account      @relation(fields: [accountId], references: [id])
}

model RecurringTemplate {
  id            String          @id @default(cuid())
  name          String
  memo          String
  paymentMethod String?
  schedule      String
  customCron    String?
  nextDue       DateTime
  autoPost      Boolean         @default(false)
  lines         RecurringLine[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model RecurringLine {
  id         String            @id @default(cuid())
  templateId String
  accountId  String
  type       String
  amount     Int
  template   RecurringTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  account    Account           @relation(fields: [accountId], references: [id])
}

model PeriodConfig {
  id                     String  @id @default("singleton")
  fiscalYearEndMonth     Int     @default(12)
  fiscalYearEndDay       Int     @default(31)
  closeFrequency         String  @default("year-end")
  retainedEarningsAcctId String?
}

model ClosedPeriod {
  id       String   @id @default(cuid())
  year     Int
  month    Int
  closedAt DateTime @default(now())
  entryId  String
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("Viewer")
  createdAt    DateTime @default(now())
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AuditEvent {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String?
  detailJson String?
  createdAt  DateTime @default(now())
}

model BankRule {
  id            String   @id @default(cuid())
  name          String
  priority      Int      @default(100)
  enabled       Boolean  @default(true)
  matchField    String
  matchType     String
  pattern       String
  accountId     String?
  entryType     String   @default("expense")
  memo          String?
  paymentMethod String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ReconciliationSession {
  id                 String   @id @default(cuid())
  accountId          String
  statementDate      DateTime
  endingBalance      Int
  status             String   @default("open")
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  items              ReconciliationItem[]
}

model ReconciliationItem {
  id        String @id @default(cuid())
  sessionId String
  entryId   String
  cleared   Boolean @default(false)
  session   ReconciliationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, entryId])
}

model PluginCategory {
  id          String   @id
  name        String
  description String
  permissions String
  enabled     Boolean  @default(false)
  builtIn     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
